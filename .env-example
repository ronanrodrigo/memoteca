# Vercel (required for deployment)
# Configure via: make setup-vercel-secrets
# (reads VERCEL_ORG_ID and VERCEL_PROJECT_ID from .vercel/project.json automatically;
#  only asks for VERCEL_TOKEN and writes the 3 as GitHub Actions Secrets)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Supabase (optional — only required if SUPABASE=1 in the scaffold)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
