# Deploy (Vercel) — required for deploy-preview/deploy-production in the project-repo.
# Configure via: make setup-vercel-secrets
# (reads VERCEL_ORG_ID and VERCEL_PROJECT_ID from .vercel/project.json automatically;
#  only asks for VERCEL_TOKEN and writes the 3 as GitHub Actions Secrets)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Supabase (optional — only required if SUPABASE=1 in the scaffold)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── Board (the central "Memoteca" GitHub Project V2) ───────────────────
# The board identity (owner + number + node ID) is resolved at runtime by
# `.memotek/scripts/project-common.sh`: it lists the current user's projects
# and matches one titled "Memoteca" (overridable via MEMOTEK_PROJECT_TITLE).
# No .env entry is required.
# Optional override:
# MEMOTEK_PROJECT_TITLE=Memoteca

# ── Orchestrator workspace (cross-repo) ────────────────────────────────
# Default: ~/Developer/memotek-workspaces
# Each Todo item from the board is dispatched into its own clone (or reuses an
# existing one) of the target repo under this dir, with a worktree per task.
# MEMOTEK_WORKSPACE_DIR=~/Developer/memotek-workspaces