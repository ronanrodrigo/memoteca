# Vercel (requerido para deploy)
# Configure via: make setup-vercel-secrets
# (lê VERCEL_ORG_ID e VERCEL_PROJECT_ID de .vercel/project.json automaticamente;
#  pede só o VERCEL_TOKEN e grava os 3 como GitHub Actions Secrets)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Supabase (opcional — só necessário se SUPABASE=1 no scaffold)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
